---
interface Props {
  eyebrow?: string;
  title: string;
  excerpt: string;
  image: string;
  href?: string;
}
import { mediaUrl } from '../lib/media';

const { eyebrow, title, excerpt, image, href } = Astro.props;
const base = import.meta.env.BASE_URL;
const resolvedImage = mediaUrl(image);
const resolvedHref = href?.startsWith('/') ? base + href.slice(1) : href;
---

<article class="news-card">
  {resolvedHref ? (
    <a href={resolvedHref} class="news-card__link-wrap" tabindex="-1" aria-hidden="true">
      <div class="news-card__media">
        <img src={resolvedImage} alt="" loading="lazy" />
      </div>
    </a>
  ) : (
    <div class="news-card__link-wrap">
      <div class="news-card__media">
        <img src={resolvedImage} alt="" loading="lazy" />
      </div>
    </div>
  )}
  <div class="news-card__body">
    {eyebrow && <div class="news-card__eyebrow">{eyebrow}</div>}
    <h3 class="news-card__title">
      {resolvedHref ? <a href={resolvedHref}>{title}</a> : title}
    </h3>
    <p class="news-card__excerpt">{excerpt}</p>
    {resolvedHref && <a href={resolvedHref} class="news-card__read">Weiterlesen <span aria-hidden="true">→</span></a>}
  </div>
</article>

<style>
  .news-card {
    background: #fff;
    border-radius: 8px;
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--dur-mid) var(--ease),
                box-shadow var(--dur-mid) var(--ease);
  }
  .news-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

  .news-card__link-wrap {
    display: block;
    overflow: hidden;
  }

  .news-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .news-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease);
  }
  .news-card:hover .news-card__media img {
    transform: scale(1.04);
  }

  .news-card__body {
    padding: 32px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .news-card__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6da649;
  }

  .news-card__title {
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.25;
    font-weight: 600;
    color: #1f221c;
    margin: 0;
  }
  .news-card__title a {
    color: inherit;
    text-decoration: none;
  }
  .news-card__title a:hover {
    color: #6da649;
    text-decoration: none;
  }

  .news-card__excerpt {
    font-size: 16px;
    line-height: 1.6;
    color: #3d413a;
    margin: 0;
    flex: 1;
  }

  .news-card__read {
    font-size: 14px;
    font-weight: 600;
    color: #6da649;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    transition: gap 150ms var(--ease), color 150ms var(--ease);
  }
  .news-card__read:hover {
    color: #4f7e33;
    gap: 8px;
    text-decoration: none;
  }

  @media (max-width: 840px) {
    .news-card__body {
      padding: 24px;
    }
  }
</style>
