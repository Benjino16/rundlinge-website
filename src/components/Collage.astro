---
interface Props {
  images: string[];
  label?: string;
}
const { images, label } = Astro.props;
---

{images.length > 0 && (
  <section class="collage">
    {label && <div class="collage__label">{label}</div>}
    <div class="collage__grid">
      {images.map((src, i) => (
        <div class="collage__cell">
          <img src={src} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .collage {
    padding: 64px 80px;
    background: #fbfaf5;
  }

  .collage__label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6da649;
    max-width: 1280px;
    margin: 0 auto 32px;
  }

  .collage__grid {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .collage__cell {
    overflow: hidden;
    border-radius: 8px;
  }

  .collage__cell img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 500ms cubic-bezier(0.32, 0.72, 0.24, 1);
  }
  .collage__cell:hover img {
    transform: scale(1.04);
  }

  @media (max-width: 840px) {
    .collage {
      padding: 48px 16px;
    }
    .collage__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 6px;
    }
  }
</style>
