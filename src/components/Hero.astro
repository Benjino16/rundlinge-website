---
interface Props {
  eyebrow?: string;
  title: string;
  image: string;
}
const { eyebrow, title, image } = Astro.props;
---

<section
  class="hero"
  style={`background-image: linear-gradient(180deg, rgba(31,34,28,0.10), rgba(31,34,28,0.45)), url(${image})`}
>
  <div class="hero__content">
    {eyebrow && <div class="hero__eyebrow">{eyebrow}</div>}
    <h1 class="hero__title" set:html={title} />
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 80px);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
  }

  .hero__content {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 96px 80px;
  }

  .hero__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e8e6c4;
    margin-bottom: 16px;
  }

  .hero__title {
    font-size: clamp(48px, 9vw, 120px);
    line-height: 0.95;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.22);
    margin: 0;
    text-wrap: balance;
  }

  @media (max-width: 840px) {
    .hero {
      min-height: 70vh;
    }
    .hero__content {
      padding: 64px 16px;
    }
    .hero__title {
      font-size: 48px;
    }
  }
</style>
