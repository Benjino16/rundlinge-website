---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const base = import.meta.env.BASE_URL;

const navItems = [
  { label: 'Neues',          href: base + 'neues' },
  { label: 'Gemeinsam',      href: base + 'gemeinsam' },
  { label: 'Lebens(t)raum',  href: base + 'lebenstraum' },
  { label: 'Öko? Logisch',   href: base + 'oekologisch' },
  { label: 'Kontakt',        href: base + 'kontakt' },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="site-header" id="site-header">
  <div class="site-header__inner">
    <a href={base} class="site-header__logo" aria-label="Am Rundling — Startseite">
      <img src={base + 'logo.png'} alt="Am Rundling" height="54" />
    </a>
    <nav class="site-header__nav" aria-label="Hauptnavigation">
      {navItems.map(({ label, href }) => (
        <a
          href={href}
          class={`site-header__navitem${isActive(href) ? ' is-active' : ''}`}
        >
          {label}
        </a>
      ))}
    </nav>
    <button
      class="site-header__burger"
      id="burger-btn"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="site-header__drawer" id="nav-drawer" aria-hidden="true">
    {navItems.map(({ label, href }) => (
      <a
        href={href}
        class={`site-header__drawer-item${isActive(href) ? ' is-active' : ''}`}
      >
        {label}
      </a>
    ))}
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const burger = document.getElementById('burger-btn')!;
  const drawer = document.getElementById('nav-drawer')!;

  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 60);
  }, { passive: true });

  burger.addEventListener('click', () => {
    const isOpen = header.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
    burger.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
    drawer.setAttribute('aria-hidden', String(!isOpen));
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    box-shadow: 0 1px 0 #e7e8e4;
    transition: box-shadow 250ms cubic-bezier(0.32, 0.72, 0.24, 1);
  }
  .site-header.is-scrolled {
    box-shadow: 0 2px 12px rgba(31,34,28,0.06);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
    height: 80px;
  }

  .site-header__logo img {
    height: 54px;
    width: auto;
    display: block;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .site-header__navitem {
    font-size: 15px;
    font-weight: 500;
    color: #1f221c;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 150ms cubic-bezier(0.32, 0.72, 0.24, 1),
                border-color 150ms cubic-bezier(0.32, 0.72, 0.24, 1);
  }
  .site-header__navitem:hover,
  .site-header__navitem.is-active {
    color: #6da649;
    text-decoration: none;
  }
  .site-header__navitem.is-active {
    border-bottom-color: #6da649;
  }

  /* Burger button */
  .site-header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .site-header__burger span {
    display: block;
    height: 2px;
    background: #1f221c;
    border-radius: 1px;
    transition: transform 250ms cubic-bezier(0.32, 0.72, 0.24, 1),
                opacity 150ms cubic-bezier(0.32, 0.72, 0.24, 1);
    transform-origin: center;
  }

  /* Burger → X animation */
  .is-open .site-header__burger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .is-open .site-header__burger span:nth-child(2) {
    opacity: 0;
  }
  .is-open .site-header__burger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Drawer */
  .site-header__drawer {
    display: none;
    flex-direction: column;
    background: #fff;
    border-top: 1px solid #e7e8e4;
    overflow: hidden;
    max-height: 0;
    transition: max-height 250ms cubic-bezier(0.32, 0.72, 0.24, 1);
  }
  .is-open .site-header__drawer {
    max-height: 400px;
  }

  .site-header__drawer-item {
    display: block;
    padding: 14px 16px;
    font-size: 16px;
    font-weight: 500;
    color: #1f221c;
    border-bottom: 1px solid #e7e8e4;
    text-decoration: none;
    transition: color 150ms;
  }
  .site-header__drawer-item:hover,
  .site-header__drawer-item.is-active {
    color: #6da649;
    text-decoration: none;
  }

  @media (max-width: 840px) {
    .site-header__inner {
      padding: 0 16px;
      height: 64px;
    }
    .site-header__logo img {
      height: 44px;
    }
    .site-header__nav {
      display: none;
    }
    .site-header__burger {
      display: flex;
    }
    .site-header__drawer {
      display: flex;
    }
  }
</style>
