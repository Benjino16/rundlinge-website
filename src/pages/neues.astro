---
import Site from '../layouts/Site.astro';
import Hero from '../components/Hero.astro';
import ContentBlock from '../components/ContentBlock.astro';

const saunaText = 'Wir haben es geschafft, den Platz in unserer Mitte um einen neuen Begegnungsort zu erweitern: unsere Sauna! Das Projekt umfasst zudem eine geplante offene Sommerküche, die als Ort für alltägliche Treffen und Feste dienen soll.';

const energieText = 'Die aktuelle Initiative beinhaltet dezentralisierte Warmwasserwärmepumpen, erweiterte Photovoltaikanlage, Speicher sowie eine neue Grauwasseranlage.';

const leuchtetText = 'Seit 2019 ist das Beleuchtungskonzept abgeschlossen mit Fokus auf Insektenschutz. Wichtig war uns auch den Insekten zuliebe die Lichtverschmutzung minimal zu halten. Seit 2017 werden mehrere Bienenvölker gepflegt, mit lokalem Honig als Ertrag.';

const herzstueckText = 'Das 80-Quadratmeter-Gebäude ist das erste Strohballenhaus Berlins. Erbaut 2009 mit vielen Eigenleistungen, bietet es Multifunktionsraum, Werkstatt, Bad, Basarecke und Lagerbereich für gemeinschaftliche Aktivitäten.';
---

<Site
  title="Neues"
  description="Aktuelle Nachrichten vom Wohnprojekt am Rundling — was wir bauen, was summt, leuchtet oder duftet."
>
  <Hero
    eyebrow="Neues · 26"
    title="Neues vom Rundling"
    image="/images/neues-hero.jpg"
  />

  <ContentBlock
    eyebrow="Energiekonzept · 2026"
    title="Wärme, Strom, Wasser — neu gedacht"
    body={energieText}
    image="/images/herzstueck-bau.jpg"
    cta={{ text: 'Mehr erfahren', href: '/oekologisch' }}
  />

  <ContentBlock
    eyebrow="Bau der Sauna · 2023"
    title="Sauna und (Sommerküche)"
    body={saunaText}
    image="/images/sauna-sommerkueche.jpg"
    cta={{ text: 'Mehr erfahren', href: '/gemeinsam' }}
    reverse={true}
    tint={true}
  />

  <ContentBlock
    eyebrow="Insektenfreundlich · 2017"
    title="Es leuchtet und summt"
    body={leuchtetText}
    image="/images/bienen.jpg"
  />

  <ContentBlock
    eyebrow="Gemeinschaftshaus · 2009"
    title="Unser Herzstück"
    body={herzstueckText}
    image="/images/herzstueck.jpg"
    cta={{ text: 'Mehr erfahren', href: '/gemeinsam#herzstueck' }}
    reverse={true}
    tint={true}
  />
</Site>
