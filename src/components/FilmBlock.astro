---
interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  meta: string;
  src: string;
  iframeTitle?: string;
  allow?: string;
  referrerpolicy?: string;
  aspectRatio?: string;
  reverse?: boolean;
}

const {
  eyebrow = 'Film',
  title,
  lede,
  meta,
  src,
  iframeTitle,
  allow = 'autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media',
  referrerpolicy,
  aspectRatio = '16 / 9',
  reverse = false,
} = Astro.props;
---

<section class="film">
  <div class={`film__inner${reverse ? ' film__inner--reverse' : ''}`}>
    <div class="film__embed" style={`--aspect: ${aspectRatio}`}>
      <iframe
        src={src}
        title={iframeTitle}
        allow={allow}
        referrerpolicy={referrerpolicy}
        allowfullscreen
        frameborder="0"
      ></iframe>
    </div>
    <div class="film__text">
      <div class="film__eyebrow">{eyebrow}</div>
      <h2 class="film__title">{title}</h2>
      <p class="film__lede">{lede}</p>
      <p class="film__meta"><small>{meta}</small></p>
    </div>
  </div>
</section>

<style>
  .film {
    background: #f4f2dc;
    padding: 96px 80px;
  }
  .film__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .film__inner--reverse {
    direction: rtl;
  }
  .film__inner--reverse > * {
    direction: ltr;
  }
  .film__embed {
    position: relative;
    width: 100%;
    aspect-ratio: var(--aspect, 16 / 9);
    border-radius: 16px;
    overflow: hidden;
  }
  .film__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .film__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6da649;
    margin-bottom: 16px;
  }
  .film__title {
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1.05;
    font-weight: 600;
    color: #1f221c;
    margin: 0 0 20px;
  }
  .film__lede {
    font-size: clamp(18px, 2vw, 20px);
    line-height: 1.55;
    color: #3d413a;
    margin: 0 0 16px;
    max-width: 48ch;
  }
  .film__meta small {
    font-size: 13px;
    color: #6b6f66;
  }
  @media (max-width: 840px) {
    .film { padding: 64px 16px; }
    .film__inner { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
